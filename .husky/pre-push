branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$branch" = "main" ] || [ "$branch" = "master" ] || [ "$branch" = "develop" ]; then
  echo ""
  echo "Push rejected. Direct pushes to '$branch' are not allowed."
  echo "Create a feature branch and use a pull request to merge into $branch."
  echo ""
  exit 1
fi

# Ensure Node 22 (load nvm even in non-interactive shells)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
if command -v nvm >/dev/null 2>&1; then
  nvm use 22 >/dev/null || true
fi

npm run lint
npm run format:check
npm run typecheck
