branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
  echo ""
  echo "Push rejected. Direct pushes to '$branch' are not allowed."
  echo "Create a feature branch and use a pull request to merge into $branch."
  echo ""
  exit 1
fi

npm run lint
npm run format:check
npm run typecheck
