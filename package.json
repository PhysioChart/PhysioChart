    "nuxt": "^4.3.1",
    "reka-ui": "^2.8.2",
    "shadcn-nuxt": "^2.4.3",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.1",
    "@tailwindcss/vite": "^4.2.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
